{
  "openapi": "3.0.0",
  "info": {
    "title": "Offline AI Agent Security API",
    "version": "1.0.0",
    "description": "가상 에이전트 안전진단 모듈용 OpenAPI 규격 가이드라인"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "서버 상태 확인",
        "responses": {
          "200": {
            "description": "정상 구동 중",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "agent": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
